{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Redis": {
    "ConnectionString": "127.0.0.1:16379"
  },
  "MongoDb": {
    "ConnectionString": "",
    "Database": "hongdal_dev"
  },
  "GoogleGeocodingApiKey": "",
  "Jwt": {
    "Issuer": "Hongdal.Dev",
    "Audience": "HongdalMaui.Dev",
    "SecretKey": "",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 14
  },
  "TossPayments": {
    "ClientKey": "",
    "SecretKey": "",
    "BaseUrl": "https://api.tosspayments.com"
  },
  "GoogleCloudStorage": {
    "BucketName": "your-dev-bucket-name",
    "ServiceAccountJsonPath": "",
    "PublicBaseUrl": "https://storage.googleapis.com"
  },
  "NaverCloudDirections": {
    "BaseUrl": "https://maps.apigw.ntruss.com",
    "Path": "/map-direction/v1/driving",
    "ApiKeyId": "",
    "ApiKey": "",
    "DefaultOption": "trafast"
  },
  "Opinet": {
    "BaseUrl": "https://www.opinet.co.kr",
    "AveragePricePath": "/api/avgAllPrice.do",
    "CertKey": "",
