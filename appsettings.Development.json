  },
  "NtsBusinessRegistration": {
    "BaseUrl": "https://api.odcloud.kr/api/nts-businessman/v1",
    "StatusPath": "/status",
    "ServiceKey": ""
  },
  "DriverUsagePolicy": {
    "오픈베타무료": true,
    "건당이용료": 500,
    "월상한": 5000
  },
  "CommandProcessing": {
    "Defaults": {
      "AuditLogEnabled": true,
      "SmsEnabled": false,
      "SnsEnabled": false,
      "PushEnabled": false,
      "EventName": "CommandHandled",
      "Target": ""
    },
    "Commands": {
      "배차수락Command": {
        "AuditLogEnabled": true,
        "PushEnabled": true,
        "EventName": "DispatchAccepted",
        "Target": "Driver"
      },
      "배차거절Command": {
        "AuditLogEnabled": true,
        "EventName": "DispatchRejected",
        "Target": "Driver"
      },
      "운송상차지도착Command": {
        "AuditLogEnabled": true,
        "EventName": "TransportArrivedPickup",
        "Target": "Driver"
      },
      "운송상차완료Command": {
        "AuditLogEnabled": true,
        "PushEnabled": true,
        "EventName": "TransportPickupCompleted",
        "Target": "Driver"
      },
      "운송하차지도착Command": {
        "AuditLogEnabled": true,
        "EventName": "TransportArrivedDropoff",
        "Target": "Driver"
      },
      "운송인수완료Command": {
        "AuditLogEnabled": true,
        "SmsEnabled": true,
        "PushEnabled": true,
        "EventName": "TransportCompleted",
        "Target": "Driver"
      },
      "운송문제신고Command": {
        "AuditLogEnabled": true,
        "SmsEnabled": true,
        "SnsEnabled": true,
        "EventName": "TransportIssueReported",
        "Target": "Admin"
